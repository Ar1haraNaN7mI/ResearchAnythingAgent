# --- LLM backend (choose one primary via LLM_PROVIDER) ---
LLM_PROVIDER=
# claude | ollama | qwen  (empty = auto: first matching key/model below)

ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=
LLM_MAX_TOKENS=4096

# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Qwen via Alibaba DashScope OpenAI-compatible API
# https://help.aliyun.com/zh/model-studio/developer-reference/use-qwen-by-calling-api
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=

# Env setup (env setup <preset>): max shell attempts per step (initial + repair retries)
ENV_SETUP_STEP_ATTEMPTS=5
# After web search, fetch top result URLs with Scrapling and convert HTML→Markdown for the planner LLM
# ENV_SETUP_SCRAPLING_DISABLE=0
# ENV_SETUP_SCRAPLING_URLS_PER_QUERY=2
# ENV_SETUP_SCRAPLING_MAX_URLS=8
# ENV_SETUP_SCRAPLING_MAX_CHARS=24000
# ENV_SETUP_SCRAPLING_PER_URL_CHARS=8000

# Next AI Draw.io (repo: next-ai-draw-io/, default dev port 6002 — see RESEARCH_AGENT.md)
# NEXT_DRAWIO_URL=http://127.0.0.1:6002
# Diagram exports (PNG/SVG/drawio); MCP export_diagram uses same path when relative
# DRAWIO_EXPORT_DIR=
# PNG default: transparent | white (file drawio_exports/.png_background overrides if env unset)
# DRAWIO_EXPORT_PNG_BACKGROUND=transparent

# Local knowledge base (kb add / FTS under knowledge_base/)
# KNOWLEDGE_BASE_DIR=
# KB_RETRIEVE_MAX_CHARS=6000
# KB_RETRIEVE_DISABLE=0
# Web KB upload max size (bytes)
# KNOWLEDGE_UPLOAD_MAX_BYTES=52428800
# Allow ?sync / kb sync to git commit + push knowledge_base/github_sync/
# KNOWLEDGE_GIT_SYNC_ALLOW=0
